# Agenthood Studio — Environment Variables
# Copy this file to .env.local and fill in your keys.

# Required — used by the server-side adapter for chat requests:
OPENCODE_API_KEY=oc-...

# Optional — for provider switching in the Studio UI:
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk-...
OPENAI_API_KEY=sk-...

# Optional — self-hosted Ollama endpoint:
OLLAMA_HOST=http://localhost:11434
