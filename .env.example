# Agenthood Studio — Environment Variables
# Copy this file to .env.local and fill in your keys.

# Required — used by the server-side adapter for chat requests:
OPENCODE_API_KEY=oc-...

# Optional — for provider switching in the Studio UI:
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk-...
OPENAI_API_KEY=sk-...

# Optional — self-hosted Ollama endpoint:
OLLAMA_HOST=http://localhost:11434

# Required for Cloudflare Turnstile CAPTCHA (playground chat anti-bot):
# Get keys from https://dash.cloudflare.com -> Turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# Optional — Sentry error tracking:
# Get DSN from https://sentry.io -> Project Settings -> Client Keys (DSN)
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_DSN=""

# Optional — Upstash Redis for rate limiting (production only):
# Provision via Vercel Storage -> KV or https://upstash.com
# KV_REST_API_URL=""
# KV_REST_API_TOKEN=""
