    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "agenthood": "3.5.2",
    "next": "^16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
